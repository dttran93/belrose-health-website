rules_version = '2';
service cloud.firestore {

  // ============================================
  // GLOBAL HELPER FUNCTIONS
  // ============================================

  // Restrict writes to the Admin SDK only
  // The Admin SDK request will have auth but NO token payload
  function isServerWrite() {
    return request.auth != null && !('token' in request.auth);
  }
  
  match /databases/{database}/documents {
    
    // ============================================
    // DATABASE-SCOPED HELPER FUNCTIONS
    // ============================================

    // Check if the authenticated user is a platform admin.
    // Reads from the custom auth claim set via Admin SDK — same source the
    // frontend RequiresPlatformAdmin guard uses (idTokenResult.claims.platformAdmin).
    // Using the token avoids a get() call and works reliably for list queries.
    function isPlatformAdmin() {
      return request.auth.token.get('platformAdmin', false) == true;
    }

    // Check if user has any role on a record
    function hasRoleOnRecord(recordId) {
      let record = get(/databases/$(database)/documents/records/$(recordId));
      return record != null && (
        record.data.uploadedBy == request.auth.uid ||
        request.auth.uid in record.data.owners ||
        request.auth.uid in record.data.administrators ||
        request.auth.uid in record.data.get('sharers', []) ||
        request.auth.uid in record.data.viewers ||
        request.auth.uid in record.data.subjects
      );
    }

    // Check if user is sharer or above on a record (can grant viewer/sharer access)
    function isSharerOrAboveOnRecord(recordId) {
      let record = get(/databases/$(database)/documents/records/$(recordId)).data;
      return record != null && (
        request.auth.uid in record.owners ||
        request.auth.uid in record.administrators ||
        request.auth.uid in record.get('sharers', [])
      );
    }
      
    // Check if user is admin or owner of a record
    function isAdminOrOwnerOfRecord(recordId) {
      let record = get(/databases/$(database)/documents/records/$(recordId)).data;
      return record != null && (
        request.auth.uid in record.owners ||
        request.auth.uid in record.administrators
      );
    }

    // Ensure the record won't be left without management after update
    function willHaveManagement() {
      let hasOwners = "owners" in request.resource.data && request.resource.data.owners.size() > 0;
      let hasAdmins = "administrators" in request.resource.data && request.resource.data.administrators.size() > 0;
      return hasOwners || hasAdmins;
    }

    // Check if owners array is being modified
    function isModifyingOwners() {
      return request.resource.data.owners != resource.data.owners;
    }

    // Check if update is ONLY adding self to subjects array
    function isOnlyAddingSelfAsSubject() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let isRightKeys = affectedKeys.hasOnly(['subjects', 'lastModified']);
      let subjectsBefore = resource.data.get('subjects', []);
      let subjectsAfter = request.resource.data.subjects;
      let arrayGrewCorrectly = subjectsAfter.size() == subjectsBefore.size() + 1;
      let addedSelf = request.auth.uid in subjectsAfter && !(request.auth.uid in subjectsBefore);
      return isRightKeys && arrayGrewCorrectly && addedSelf;
    }

    // Check if user is removing themselves as a subject
    function isSelfRejectionFlow() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let isRightKeys = affectedKeys.hasOnly(['subjects', 'viewers', 'sharers', 'lastModified']);
      let removedSelf = !(request.auth.uid in request.resource.data.subjects) &&
                        (request.auth.uid in resource.data.subjects);
      return isRightKeys && removedSelf;
    }

    // Check if a controller trustee is anchoring their trustor as a subject.
    // The write includes a `controllerAnchorFor` proof field containing the trustorId,
    // which lets the rule look up the specific trusteeRelationships doc without needing
    // to compute an array diff (not possible in Firestore rules).
    function isControllerAddingTrustorAsSubject() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let subjectsBefore = resource.data.get('subjects', []);
      let subjectsAfter = request.resource.data.subjects;
      let trustorId = request.resource.data.get('controllerAnchorFor', '');
      let trustorRelId = trustorId + '_' + request.auth.uid;
      let relExists = trustorId != '' &&
        exists(/databases/$(database)/documents/trusteeRelationships/$(trustorRelId));
      return affectedKeys.hasOnly(['subjects', 'lastModified', 'controllerAnchorFor']) &&
        subjectsAfter.size() == subjectsBefore.size() + 1 &&
        trustorId in subjectsAfter &&
        !(trustorId in subjectsBefore) &&
        !(request.auth.uid in subjectsAfter && !(request.auth.uid in subjectsBefore)) &&
        (request.auth.uid in resource.data.get('owners', []) ||
         request.auth.uid in resource.data.get('administrators', [])) &&
        relExists &&
        get(/databases/$(database)/documents/trusteeRelationships/$(trustorRelId)).data.isActive == true &&
        get(/databases/$(database)/documents/trusteeRelationships/$(trustorRelId)).data.trustLevel == 'controller';
    }

    // ============================================
    // USER PROFILES/NOTIFICATIONS/CHATS
    // ============================================

    match /users/{userId} {
      // Any authenticated user can read profiles (needed for sharing/search)
      allow read: if request.auth != null;

      // Owner can create their own profile, but cannot self-assign platform admin
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.get('isPlatformAdmin', false) != true;

      // Owner can update their own profile, but cannot change isPlatformAdmin
      allow update: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.get('isPlatformAdmin', false) == resource.data.get('isPlatformAdmin', false);

      // Owner can delete their own profile
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // --- NOTIFICATIONS SUBCOLLECTION ---
      match /notifications/{notificationId} {
        // Users can only read their own notifications
        allow read: if request.auth != null && request.auth.uid == userId;
        
        // Notifications are ONLY created by the server (Cloud Functions)
        allow create: if request.auth.uid == userId &&
        	request.resource.data.read == false &&
          request.resource.data.createdAt is timestamp &&
          isServerWrite();
        
        // Users can ONLY mark a notification as read
        allow update: if request.auth != null &&
        								request.auth.uid == userId &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                        request.resource.data.read == true;
        
        // Deletion is restricted to the server (for cleanup jobs)
        allow delete: if request.auth.uid == userId && isServerWrite();
      }

      // -- AI CHATS COLLECTION ---
      match /chats/{chatId} {
        // Helper: Check if user owns this chat
        function isOwner() {
          return request.auth != null && request.auth.uid == userId;
        }

        // READ: Only the chat owner can read their chats
        allow read: if isOwner();

        // CREATE: User can create chats in their own collection
        // Encrypted fields (title, titleIv) stored directly in document
        allow create: if isOwner() &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.updatedAt is timestamp &&
          request.resource.data.messageCount == 0 &&
          request.resource.data.recordCount >= 0 &&
          // Title must be encrypted (placeholder only)
          request.resource.data.title is string;

        // UPDATE: User can update their own chats
        // - Can update encrypted title, context info, message count, preview
        // - Cannot modify createdAt
        // - Must update updatedAt
        allow update: if isOwner() &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.updatedAt is timestamp;

        // DELETE: User can delete their own chats
        allow delete: if isOwner();

        // --- AI CHAT MESSAGES SUBCOLLECTION ---
        match /messages/{messageId} {
          // READ: Only chat owner can read messages
          allow read: if request.auth != null && request.auth.uid == userId;

          // CREATE: Only chat owner can add messages
          // Encrypted content stored directly in message document
          allow create: if request.auth != null &&
            request.auth.uid == userId &&
            request.resource.data.role in ['user', 'assistant'] &&
            request.resource.data.timestamp is timestamp &&
            // Content must be encrypted (placeholder only)
            request.resource.data.content is string;

          // UPDATE: Not allowed - messages are immutable
          allow update: if false;

          // DELETE: Only chat owner can delete messages
          allow delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // --- MESSAGE BACKUPS SUBCOLLECTION ---
      match /messageBackups/{conversationId} {
        // Only the owner can read/write their own backups.
        // The backup contains AES-encrypted plaintext — nobody else
        // should be able to read or modify it.
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================================
    // WRAPPED CHAT KEYS
    // ============================================
    
    match /wrappedChatKeys/{wrappedKeyId} {
      // wrappedKeyId format: {chatId}_{userId}
      
      // Helper: Extract userId from document ID
      function extractUserId() {
        return wrappedKeyId.split('_')[1];
      }

      // READ: Only the key owner can read
      allow read: if request.auth != null &&
        request.auth.uid == extractUserId();

      // CREATE: User can create wrapped keys for their own chats
      // Must match the document ID format and include required fields
      allow create: if request.auth != null &&
        request.auth.uid == extractUserId() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.chatId is string &&
        request.resource.data.wrappedKey is string &&
        request.resource.data.isActive == true &&
        request.resource.data.createdAt is timestamp;

      // UPDATE: User can deactivate their own keys
      allow update: if request.auth != null &&
        request.auth.uid == extractUserId() &&
        resource.data.userId == request.auth.uid &&
        // Only allow toggling isActive
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActive']);

      // DELETE: User can delete their own wrapped keys
      allow delete: if request.auth != null &&
        request.auth.uid == extractUserId() &&
        resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // RECORDS
    // ============================================

    match /records/{recordId} {
      // READ: User can read if they have any role on the record, or are a platform admin.
      // isPlatformAdmin() is checked first so collection-wide admin scans short-circuit
      // before any resource.data access (avoids evaluation errors on unfiltered list queries).
      allow read: if request.auth != null && (
        isPlatformAdmin() ||
        !exists(/databases/$(database)/documents/records/$(recordId)) ||
        resource.data.uploadedBy == request.auth.uid ||
        request.auth.uid in resource.data.owners ||
        request.auth.uid in resource.data.administrators ||
        ('sharers' in resource.data && request.auth.uid in resource.data.sharers) ||
        request.auth.uid in resource.data.viewers ||
        request.auth.uid in resource.data.subjects
      );

      // CREATE: Must be authenticated and have management structure
      allow create: if request.auth != null && willHaveManagement();
     
      // UPDATE: Multiple flows for different use cases
      // BRANCH 1: Admin/owner updating record
      allow update: if request.auth != null && (
        (
          (request.auth.uid in resource.data.administrators ||
           request.auth.uid in resource.data.owners) &&
          willHaveManagement() &&
          request.resource.data.get('subjects', []) == resource.data.get('subjects', []) &&
          (!isModifyingOwners() ||
           (resource.data.owners.size() == 0 && request.auth.uid in resource.data.administrators) ||
           (resource.data.owners.size() > 0 && request.auth.uid in resource.data.owners)) &&
          // Admins can only remove themselves from administrators — not other admins (owners are unrestricted)
          (request.auth.uid in resource.data.owners ||
           resource.data.owners.size() == 0 ||
           resource.data.get('administrators', []).removeAll([request.auth.uid]) ==
             request.resource.data.get('administrators', []).removeAll([request.auth.uid]))
        ) ||
        // BRANCH 2: Subject consent flow - user adding self to subjects
        (
          (request.auth.uid in resource.data.viewers ||
           request.auth.uid in resource.data.get('sharers', []) ||
           request.auth.uid in resource.data.administrators ||
           request.auth.uid in resource.data.owners) &&
          isOnlyAddingSelfAsSubject()
        ) ||
        // BRANCH 3: Subject rejection flow - removing self
        (
          request.auth.uid in resource.data.subjects &&
          isSelfRejectionFlow()
        ) ||
        // BRANCH 4: Credibility score update
        (
          (request.auth.uid in resource.data.owners ||
          request.auth.uid in resource.data.administrators ||
          request.auth.uid in resource.data.get('sharers', []) ||
          request.auth.uid in resource.data.viewers ||
          request.auth.uid in resource.data.subjects) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credibility'])
        ) ||
        // BRANCH 5: Sharer granting/revoking viewer access only. Sharers cannot modify the
        // sharers array — only owners and administrators can grant sharer role.
        (
          request.auth.uid in resource.data.get('sharers', []) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers', 'trustees', 'lastModified']) &&
          resource.data.owners == request.resource.data.owners &&
          resource.data.administrators == request.resource.data.administrators &&
          resource.data.get('sharers', []) == request.resource.data.get('sharers', []) &&
          resource.data.subjects == request.resource.data.subjects
        ) ||
        // BRANCH 6: Viewer removing themselves
        (
          request.auth.uid in resource.data.viewers &&
          !(request.auth.uid in resource.data.subjects) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers', 'trustees', 'lastModified']) &&
          resource.data.get('viewers', []).removeAll([request.auth.uid]) == request.resource.data.get('viewers', []) &&
          resource.data.get('trustees', []).removeAll([request.auth.uid]) == request.resource.data.get('trustees', [])
        ) ||
        // BRANCH 6b: Sharer removing themselves
        (
          request.auth.uid in resource.data.get('sharers', []) &&
          !(request.auth.uid in resource.data.subjects) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharers', 'trustees', 'lastModified']) &&
          resource.data.get('sharers', []).removeAll([request.auth.uid]) == request.resource.data.get('sharers', []) &&
          resource.data.get('trustees', []).removeAll([request.auth.uid]) == request.resource.data.get('trustees', [])
        ) ||
        // BRANCH 7: Controller trustee anchoring their trustor as subject (no consent needed)
        (
          isControllerAddingTrustorAsSubject()
        ) ||
        // BRANCH 8: Cleanup of controllerAnchorFor proof field after controller anchor
        (
          (request.auth.uid in resource.data.get('owners', []) ||
           request.auth.uid in resource.data.get('administrators', [])) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['controllerAnchorFor']) &&
          request.resource.data.diff(resource.data).removedKeys().hasOnly(['controllerAnchorFor'])
        ) ||
        // BRANCH 9: Trustee self-adjusting their own role (step-down or resign).
        // A trustee can downgrade or remove themselves from role arrays on records
        // where they hold trustee-derived access (trustees[] marker).
        // "Other users unchanged" guards + "no escalation" guards prevent abuse.
        (
          // Caller must have trustee-derived access on this record
          request.auth.uid in resource.data.get('trustees', []) &&
          // Only role arrays and trustees[] can change — no other fields
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['owners', 'administrators', 'sharers', 'viewers', 'trustees']) &&
          // Other users' role memberships must be unchanged (caller's uid filtered out)
          resource.data.get('owners', []).removeAll([request.auth.uid]) ==
            request.resource.data.get('owners', []).removeAll([request.auth.uid]) &&
          resource.data.get('administrators', []).removeAll([request.auth.uid]) ==
            request.resource.data.get('administrators', []).removeAll([request.auth.uid]) &&
          resource.data.get('sharers', []).removeAll([request.auth.uid]) ==
            request.resource.data.get('sharers', []).removeAll([request.auth.uid]) &&
          resource.data.get('viewers', []).removeAll([request.auth.uid]) ==
            request.resource.data.get('viewers', []).removeAll([request.auth.uid]) &&
          // trustees[] can only remove the caller — no other trustee entry changes
          resource.data.get('trustees', []).removeAll([request.auth.uid]) ==
            request.resource.data.get('trustees', []).removeAll([request.auth.uid]) &&
          // No escalation: caller cannot gain a role higher than they currently hold
          !(request.auth.uid in request.resource.data.get('owners', []) &&
            !(request.auth.uid in resource.data.get('owners', []))) &&
          !(request.auth.uid in request.resource.data.get('administrators', []) &&
            !(request.auth.uid in resource.data.get('administrators', [])) &&
            !(request.auth.uid in resource.data.get('owners', []))) &&
          !(request.auth.uid in request.resource.data.get('sharers', []) &&
            !(request.auth.uid in resource.data.get('sharers', [])) &&
            !(request.auth.uid in resource.data.get('administrators', [])) &&
            !(request.auth.uid in resource.data.get('owners', []))) &&
          !(request.auth.uid in request.resource.data.get('viewers', []) &&
            !(request.auth.uid in resource.data.get('viewers', [])) &&
            !(request.auth.uid in resource.data.get('administrators', [])) &&
            !(request.auth.uid in resource.data.get('owners', [])))
        )
      );

      // DELETE: Owners only, or admins if no owners exist
      allow delete: if request.auth != null && (
        request.auth.uid in resource.data.owners ||
        (resource.data.owners.size() == 0 && request.auth.uid in resource.data.administrators)
      );

      // --- PERMISSION HISTORY SUBCOLLECTION ---
      match /permissionHistory/{eventId} {
        // Read: platform admins or any user with a role on this record
        allow read: if request.auth != null && (isPlatformAdmin() || hasRoleOnRecord(recordId));

        // Create: must have a role and must be the one making the change
        allow create: if request.auth != null
          && request.resource.data.changedBy == request.auth.uid
          && hasRoleOnRecord(recordId);

        // Immutable audit log
        allow update, delete: if false;
      }
    }

    // ============================================
    // RECORD VERSIONS
    // ============================================

    match /recordVersions/{versionId} {
      allow read: if request.auth != null && hasRoleOnRecord(resource.data.recordId);

    allow create: if request.auth != null && 
      isAdminOrOwnerOfRecord(request.resource.data.recordId) && (
        // Path A: Strict Baseline Validation (Version 0)
        (
          request.resource.data.versionNumber == 0 &&
          request.resource.data.encryptedChanges == null &&
          request.resource.data.commitMessage == 'Original Upload (auto-created baseline)'
        ) || 
        
        // Path B: Standard Edit Validation (Version 1+)
        (
          request.resource.data.versionNumber > 0 &&
          request.resource.data.editedBy == request.auth.uid
        )
      );

      allow update: if false; // Versions are immutable

      allow delete: if request.auth != null &&     
      exists(/databases/$(database)/documents/records/$(resource.data.recordId)) &&
      isAdminOrOwnerOfRecord(resource.data.recordId);
    }
    
    // ============================================
    // SUBJECT CONSENT REQUESTS
    // ============================================

    match /subjectConsentRequests/{requestId} {
      // READ: User can read if they:
      // 1. Are a platform admin
      // 2. Are the target user (receiving the request)
      // 3. Requested it themselves
      // 4. Are an admin/owner of the record
      allow read: if request.auth != null && (
        isPlatformAdmin() ||
        !exists(/databases/$(database)/documents/subjectConsentRequests/$(requestId)) ||
        resource.data.subjectId == request.auth.uid ||
        resource.data.requestedBy == request.auth.uid ||
        (request.auth.uid in get(/databases/$(database)/documents/records/$(resource.data.recordId)).data.owners ||
         request.auth.uid in get(/databases/$(database)/documents/records/$(resource.data.recordId)).data.administrators)
      );

      // CREATE: Three branches:
      // 1. Admin/owner sends a pending consent request to another user
      // 2. Subject self-adds (setSubjectAsSelf) — audit record, status 'self_consented'
      // 3. Controller anchors trustor — audit record, status 'controller_consented'
      allow create: if request.auth != null && (
        // BRANCH 1: Standard pending request by admin/owner
        (
          isAdminOrOwnerOfRecord(request.resource.data.recordId) &&
          request.resource.data.requestedBy == request.auth.uid &&
          request.resource.data.status == 'pending' &&
          request.resource.data.recordId != null &&
          request.resource.data.subjectId != null &&
          request.resource.data.createdAt is timestamp &&
          (!('grantedAccessOnSubjectRequest' in request.resource.data.keys()) ||
           request.resource.data.grantedAccessOnSubjectRequest is bool)
        ) ||
        // BRANCH 2: Self-add — subject and requester are the same person
        (
          isAdminOrOwnerOfRecord(request.resource.data.recordId) &&
          request.resource.data.requestedBy == request.auth.uid &&
          request.resource.data.subjectId == request.auth.uid &&
          request.resource.data.status == 'self_consented' &&
          request.resource.data.recordId != null &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.respondedAt is timestamp
        ) ||
        // BRANCH 3: Controller anchoring trustor on their behalf
        (
          isAdminOrOwnerOfRecord(request.resource.data.recordId) &&
          request.resource.data.requestedBy == request.auth.uid &&
          request.resource.data.subjectId != request.auth.uid &&
          request.resource.data.status == 'controller_consented' &&
          request.resource.data.recordId != null &&
          request.resource.data.subjectId != null &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.respondedAt is timestamp
        )
      );

      // UPDATE: Two branches:
      // 1. Subject can accept/reject
      // 2. Requester can update grantedAccessOnSubjectRequest
      // BRANCH 1: Subject accepting/rejecting
      allow update: if request.auth != null && (
        (
          resource.data.subjectId == request.auth.uid &&
          request.resource.data.status in ['accepted', 'rejected'] &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt', 'rejection']) &&
          (!('respondedAt' in request.resource.data.diff(resource.data).affectedKeys()) || 
           request.resource.data.respondedAt is timestamp)
        ) 
        ||
        // BRANCH 2: Requester updating grantedAccessOnSubjectRequest
        (
          resource.data.requestedBy == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['grantedAccessOnSubjectRequest', 'rejection','lastModified'])
        )
      );

      // DELETE: Only the requester or record admins/owners can delete
      allow delete: if request.auth != null && (
        resource.data.requestedBy == request.auth.uid ||
        isAdminOrOwnerOfRecord(resource.data.recordId)
      );
    }

    // ============================================
    // SUBJECT REMOVAL REQUESTS
    // ============================================

    match /subjectRemovalRequests/{requestId} {
      // Helper: Check if target is actually a subject of the record
      function isSubjectOfRecord() {
        let record = get(/databases/$(database)/documents/records/$(request.resource.data.recordId));
        return request.resource.data.subjectId in record.data.subjects;
      }

      // READ: User can read if they:
      // 1. Are the subject (receiving the request)
      // 2. Requested it themselves
      // 3. Are an owner/admin of the record
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/subjectRemovalRequests/$(requestId)) ||
        resource.data.subjectId == request.auth.uid ||
        resource.data.requestedBy == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/records/$(resource.data.recordId)).data.subjects ||
        isAdminOrOwnerOfRecord(resource.data.recordId)
      );

      // CREATE: Must be authenticated AND:
      // 1. Be an owner (or admin if no owners) of the record
      // 2. Set themselves as requestedBy
      // 3. Cannot request removal of themselves
      // 4. Target must be a current subject
      // 5. Status must be 'pending'
      // 6. Required fields present
      allow create: if request.auth != null &&
        isAdminOrOwnerOfRecord(request.resource.data.recordId) &&
        request.resource.data.requestedBy == request.auth.uid &&
        request.resource.data.subjectId != request.auth.uid &&
        isSubjectOfRecord() &&
        request.resource.data.status == 'pending' &&
        request.resource.data.recordId != null &&
        request.resource.data.subjectId != null &&
        request.resource.data.createdAt is timestamp;

      // UPDATE: Only the subject can accept/reject
      allow update: if request.auth != null &&
        resource.data.subjectId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status in ['accepted', 'rejected'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt', 'subjectResponse']) &&
        request.resource.data.respondedAt is timestamp;

      // DELETE: Requester or record owners/admins can delete (for cancellation)
      allow delete: if request.auth != null && (
        resource.data.requestedBy == request.auth.uid ||
        isAdminOrOwnerOfRecord(resource.data.recordId)
      );
    }
    
    // ============================================
    // VERIFICATIONS
    // ============================================

    match /verifications/{verificationId} {
      
      // READ: Allow if user is verifier, has role on the record, or is a platform admin.
      // isPlatformAdmin() first so unfiltered admin list queries short-circuit before
      // hasRoleOnRecord() tries to get() a path containing unknown resource.data.recordId.
      allow read: if request.auth != null && (
        isPlatformAdmin() ||
        !exists(/databases/$(database)/documents/verifications/$(verificationId)) ||
        resource.data.verifierId == request.auth.uid ||
        hasRoleOnRecord(resource.data.recordId)
      );

      // CREATE: 
      // - User must have a role on the record
      // - User must be the verifier
      // - Document ID must match expected format (enforces uniqueness)
      // - Required fields validated
      allow create: if request.auth != null &&
        hasRoleOnRecord(request.resource.data.recordId) &&
        request.resource.data.verifierId == request.auth.uid &&
        // Enforce document ID format: {recordHash}_{verifierId}
        verificationId == request.resource.data.recordHash + '_' + request.auth.uid &&
        // Validate required fields
        request.resource.data.isActive == true &&
        request.resource.data.level in [1, 2, 3] &&
        request.resource.data.createdAt is timestamp;

      // Only the original verifier can modify their verification
      allow update: if request.auth != null &&
        resource.data.verifierId == request.auth.uid &&
        // Immutable fields - cannot be changed
        request.resource.data.verifierId == resource.data.verifierId &&
        request.resource.data.recordId == resource.data.recordId &&
        request.resource.data.recordHash == resource.data.recordHash &&
        request.resource.data.createdAt == resource.data.createdAt;

      // DELETE: Not allowed - use isActive flag instead
      allow delete: if false;
    }

    // ============================================
    // DISPUTES
    // ============================================
  
    match /disputes/{disputeId} {
      // READ: Allow if user is disputer, has role on the record, or is a platform admin.
      // isPlatformAdmin() first — same reason as verifications: hasRoleOnRecord()
      // uses resource.data.recordId which is unknown during unfiltered list queries.
      allow read: if request.auth != null && (
        isPlatformAdmin() ||
        !exists(/databases/$(database)/documents/disputes/$(disputeId)) ||
        resource.data.disputerId == request.auth.uid ||
        hasRoleOnRecord(resource.data.recordId)
      );

      // CREATE: 
      // - User must have a role on the record
      // - User must be the disputer
      // - Document ID must match expected format (enforces uniqueness)
      // - Required fields validated
      allow create: if request.auth != null &&
        hasRoleOnRecord(request.resource.data.recordId) &&
        request.resource.data.disputerId == request.auth.uid &&
        // Enforce document ID format: {recordHash}_{disputerId}
        disputeId == request.resource.data.recordHash + '_' + request.auth.uid &&
        // Validate required fields
        request.resource.data.isActive == true &&
        request.resource.data.severity in [1, 2, 3] &&
        request.resource.data.culpability in [0, 1, 2, 3, 4, 5] &&
        request.resource.data.createdAt is timestamp;

      // Only the original disputer can modify their dispute
      allow update: if request.auth != null &&
        resource.data.disputerId == request.auth.uid &&
        // Immutable fields - cannot be changed
        request.resource.data.disputerId == resource.data.disputerId &&
        request.resource.data.recordId == resource.data.recordId &&
        request.resource.data.recordHash == resource.data.recordHash &&
        request.resource.data.createdAt == resource.data.createdAt;

      // DELETE: Not allowed - use isActive flag instead
      allow delete: if false;
    }

    // ============================================
    // VOUCHES
    // ============================================

    match /vouches/{vouchId} {
      // READ: Any authenticated user — vouches are public trust signals
      // used for credibility score computation across the network.
      allow read: if request.auth != null;

      // CREATE: Only the voucher can create their own vouch.
      // - voucherId must match the caller (no vouching on behalf of others)
      // - Can't vouch for yourself
      // - Document ID enforces uniqueness: {voucherId}_{voucheeId}
      // - Required fields validated
      allow create: if request.auth != null &&
        request.resource.data.voucherId == request.auth.uid &&
        request.resource.data.voucheeId != request.auth.uid &&
        vouchId == request.auth.uid + '_' + request.resource.data.voucheeId &&
        request.resource.data.chainStatus == 'Active' &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.onChainHistory is list &&
        request.resource.data.onChainHistory.size() == 1;

      // UPDATE: Only the original voucher can update (retract or re-vouch).
      // Core identity fields are immutable after creation.
      allow update: if request.auth != null &&
        resource.data.voucherId == request.auth.uid &&
        request.resource.data.voucherId == resource.data.voucherId &&
        request.resource.data.voucherIdHash == resource.data.voucherIdHash &&
        request.resource.data.voucheeId == resource.data.voucheeId &&
        request.resource.data.voucheeIdHash == resource.data.voucheeIdHash &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.chainStatus in ['Active', 'Retracted'];

      // DELETE: Not allowed — vouches are a permanent audit trail.
      allow delete: if false;
    }

    // ============================================
    // SCORE EVENTS (Credibility Audit Trail)
    // ============================================
    
    match /scoreEvents/{eventId} {
      // READ: Allow if user has a role on the associated record
      // This allows users to see the credibility history for records they can access
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/scoreEvents/$(eventId)) ||
        hasRoleOnRecord(resource.data.recordId)
      );

      // CREATE: User must:
      // 1. Have a role on the record
      // 2. Be the one creating the event (createdBy matches auth uid)
      // 3. Document ID must start with recordId (format: recordId_timestamp)
      // 4. Include required fields
      allow create: if request.auth != null &&
        hasRoleOnRecord(request.resource.data.recordId) &&
        request.resource.data.createdBy == request.auth.uid &&
        // Enforce document ID starts with recordId_
        eventId.matches(request.resource.data.recordId + '_[0-9]+') &&
        request.resource.data.recordId != null &&
        request.resource.data.recordHash != null &&
        request.resource.data.eventType in [
          'verification', 
          'verification_revoked', 
          'verification_modified',
          'dispute',
          'dispute_revoked',
          'dispute_modified'
        ] &&
        request.resource.data.scoreDelta is number &&
        request.resource.data.createdAt is timestamp;

      allow update: if false; // Immutable audit trail
      allow delete: if false; // Immutable audit trail
    }

    // ============================================
    // RECORD DELETION EVENTS
    // ============================================

    match /recordDeletionEvents/{recordId} {
      // READ: Only affected users can read (for audit trail)
      allow read: if request.auth != null && (
        resource.data.deletedBy == request.auth.uid ||
        request.auth.uid in resource.data.affectedUsers.owners ||
        request.auth.uid in resource.data.affectedUsers.administrators ||
        request.auth.uid in resource.data.affectedUsers.get('sharers', []) ||
        request.auth.uid in resource.data.affectedUsers.viewers ||
        request.auth.uid in resource.data.affectedUsers.subjects
      );

      // CREATE: Only owners (or admins if no owners) can create deletion events
      // Must verify they can delete the record BEFORE creating the event
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/records/$(recordId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/records/$(recordId)).data.owners ||
        (get(/databases/$(database)/documents/records/$(recordId)).data.owners.size() == 0 && 
          request.auth.uid in get(/databases/$(database)/documents/records/$(recordId)).data.administrators)) &&
        request.resource.data.deletedBy == request.auth.uid &&
        request.resource.data.deletionComplete == false;

      // UPDATE: Only the deleter can mark as complete
      allow update: if request.auth != null &&
        resource.data.deletedBy == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletionComplete']) &&
        request.resource.data.deletionComplete == true;

      // DELETE: Only server
      allow delete: if isServerWrite();
    }

    // ============================================
    // ENCRYPTION & SECURITY
    // ============================================

    match /wrappedKeys/{wrappedKeyId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null && (
        isSharerOrAboveOnRecord(request.resource.data.recordId)
      );

      allow update: if request.auth != null && (
        isAdminOrOwnerOfRecord(resource.data.recordId) ||
        resource.data.userId == request.auth.uid ||
        (isSharerOrAboveOnRecord(resource.data.recordId) &&
        resource.data.grantedBy == request.auth.uid)
      );

      allow delete: if request.auth != null &&
        exists(/databases/$(database)/documents/records/$(resource.data.recordId)) && (
          isAdminOrOwnerOfRecord(resource.data.recordId) ||
          resource.data.userId == request.auth.uid ||
          resource.data.grantedBy == request.auth.uid
      );
    }
    
    // ============================================
    // TRUSTEE RELATIONSHIPS
    // ============================================

    match /trusteeRelationships/{relationshipId} {
      function isTrustor() {
        return request.auth.uid == resource.data.trustorId;
      }
      function isTrustee() {
        return request.auth.uid == resource.data.trusteeId;
      }

      // READ: Anybody. Is safe because document doesn't have any sensitive data
      allow read: if request.auth != null;

      // CREATE: Trustor only, with required field validation
      allow create: if request.auth != null &&
        request.resource.data.trustorId == request.auth.uid &&
        request.resource.data.trustorId != request.resource.data.trusteeId &&
        request.resource.data.status == 'pending' &&
        request.resource.data.isActive == false &&
        request.resource.data.trustLevel in ['observer', 'custodian', 'controller'] &&
        request.resource.data.trustorId != null &&
        request.resource.data.trusteeId != null &&
        request.resource.data.createdAt is timestamp;

      // UPDATE: Two branches
      allow update: if request.auth != null && (
        // BRANCH 1: Trustor managing the relationship
        (
          isTrustor() &&
          // Immutable core fields
          request.resource.data.trustorId == resource.data.trustorId &&
          request.resource.data.trusteeId == resource.data.trusteeId
        ) ||
        // BRANCH 2: Trustee accepting or declining (pending only)
        (
          isTrustee() &&
          resource.data.status == 'pending' &&
          request.resource.data.status in ['active', 'declined'] &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'isActive', 'respondedAt', 'revokedBy', 'onChainEvents']) &&
          request.resource.data.trustorId == resource.data.trustorId &&
          request.resource.data.trusteeId == resource.data.trusteeId
        )||
        // BRANCH 3: Trustee resigning
        (
          isTrustee() &&
          resource.data.status == 'active' &&
          request.resource.data.status == 'declined' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'isActive', 'revokedAt', 'revokedBy', 'statusUpdateReason', 'onChainEvents']) &&
          request.resource.data.trustorId == resource.data.trustorId &&
          request.resource.data.trusteeId == resource.data.trusteeId
        ) ||
        // BRANCH 4: Trustee self-downgrading trust level (upgrades require trustor)
        (
          isTrustee() &&
          resource.data.status == 'active' &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.trustorId == resource.data.trustorId &&
          request.resource.data.trusteeId == resource.data.trusteeId &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['trustLevel', 'statusUpdateReason', 'onChainEvents']) &&
          (
            (resource.data.trustLevel == 'controller' &&
             (request.resource.data.trustLevel == 'custodian' || request.resource.data.trustLevel == 'observer')) ||
            (resource.data.trustLevel == 'custodian' && request.resource.data.trustLevel == 'observer')
          )
        )
      );

      // DELETE: Not allowed — soft delete only
      allow delete: if false;
    }

  // ============================================
  // GUEST INVITES
  // ============================================

  match /guestInvites/{inviteId} {
    // Guest can read their own invites (to validate expiry on link click)
    allow read: if request.auth != null && (
      resource.data.guestUserId == request.auth.uid ||
      resource.data.invitedBy == request.auth.uid
    );

    // Guest can mark their own invite as accepted when claiming
    allow update: if request.auth != null &&
      resource.data.guestUserId == request.auth.uid &&
      request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'claimedAt']) &&
      request.resource.data.status == 'accepted';

    // Not deletable — permanent audit trail
    allow delete: if false;
  }

  // ============================================
  // RECORD REQUESTS
  // ============================================

  match /recordRequests/{requestId} {

    // 1. READ RULES
    // 'get' allows individual document lookups via the inviteCode.
    // 'list' allows the requester to see their dashboard.
    allow get: if true; 
    allow list: if request.auth != null && (
      request.auth.uid == resource.data.requesterId ||
      request.auth.uid == resource.data.targetUserId ||
      request.auth.token.email == resource.data.targetEmail ||
      request.auth.uid == resource.data.providerGuestUid
    );

    // 2. CREATE RULES
    allow create: if request.auth != null
                  && request.auth.uid == request.resource.data.requesterId
                  && request.resource.data.status == 'pending';

    // 3. UPDATE RULES (Combined logic)
    allow update: if (
      // Path A: Read receipt (unauthenticated stamp of readAt)
      (
        resource.data.status == 'pending' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'viewCount'])
      ) ||
  
      // Path B: Provider adds records to a pending request.
      // Can add record IDs while staying pending, or add and mark fulfilled in one write.
      (
        request.auth != null &&
        resource.data.status == 'pending' &&
        (
          request.auth.uid == resource.data.targetUserId ||
          request.auth.token.email == resource.data.targetEmail
        ) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'fulfilledRecordIds', 'fulfilledAt']) &&
        (
          // Still pending — adding record IDs
          (
            request.resource.data.status == 'pending' &&
            request.resource.data.fulfilledRecordIds.size() > 0
          ) ||
          // Marking complete — status flips to fulfilled
          (
            request.resource.data.status == 'fulfilled' &&
            request.resource.data.fulfilledRecordIds.size() > 0
          )
        )
      ) ||
  
      // Path C: Requester cancels
      (
        request.auth != null &&
        request.auth.uid == resource.data.requesterId &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'cancelledAt', 'lastRemindedAt'])
      ) ||
  
      // Path D: Provider rewraps note key after claiming account
      (
        request.auth != null &&
        (
          request.auth.uid == resource.data.targetUserId ||
          request.auth.token.email == resource.data.targetEmail ||
          request.auth.uid == resource.data.providerGuestUid
        ) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['encryptedNoteKeyForProvider'])
      ) ||
  
      // Path E: Provider marks request complete (fulfilled)
      //         At least one record must already be linked.
      (
        request.auth != null &&
        resource.data.status == 'pending' &&
        (
          request.auth.uid == resource.data.targetUserId ||
          request.auth.token.email == resource.data.targetEmail
        ) &&
        request.resource.data.status == 'fulfilled' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'fulfilledAt'])
      ) ||
  
      // Path F: Provider denies request
      (
        request.auth != null &&
        resource.data.status == 'pending' &&
        (
          request.auth.uid == resource.data.targetUserId ||
          request.auth.token.email == resource.data.targetEmail
        ) &&
        request.resource.data.status == 'denied' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'deniedAt', 'deniedReason', 'deniedNote'])
      ) ||
      // Path G: Guest claiming account — backfill their userId
      (
        request.auth != null &&
        request.auth.token.email == resource.data.targetEmail &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['targetUserId']) &&
        request.resource.data.targetUserId == request.auth.uid
      )
    );
  }

  // ============================================
  // MESSAGING
  // ============================================
  
    match /conversations/{conversationId} {
      function isParticipant() {
        return request.auth.uid in resource.data.participants;
      }
    
      // Helper for creates — resource doesn't exist yet so we read from request
      function isParticipantOnCreate() {
        return request.auth.uid in request.resource.data.participants;
      }
    
      // READ: Only participants can read a conversation
      allow read: if request.auth != null && (
        !exists(/databases/$(database)/documents/conversations/$(conversationId)) ||
        isParticipant()
      );
    
      // CREATE: Any authenticated user can create a conversation provided:
      //   - They include themselves as a participant (can't create on behalf of others)
      //   - Exactly 2 participants (direct messaging only for now)
      //   - Required metadata fields are present
      allow create: if request.auth != null &&
        isParticipantOnCreate() &&
        request.resource.data.participants.size() == 2 &&
        request.resource.data.participants is list &&
        request.resource.data.lastMessageAt == null;
    
      // UPDATE: Only participants can update, and only the metadata fields
      // that messageService.sendMessage() touches. Message content itself
      // lives in the subcollection — this document is just housekeeping.
      allow update: if request.auth != null &&
        isParticipant() &&
        // Participants list is immutable — conversations can't be reassigned
        request.resource.data.participants == resource.data.participants &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // Only these fields can change
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['lastMessageAt', 'lastReadAt', 'encryptedKeys']);
    
      // DELETE: Not allowed — conversations are permanent records
      // (soft delete via a field could be added later if needed)
      allow delete: if false;
    
      // --- MESSAGES SUBCOLLECTION ---
      match /messages/{messageId} {
    
        // READ: Only conversation participants can read messages
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    
        // CREATE: Only participants can send messages
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.body is string &&
          request.resource.data.body.size() > 0 &&
          request.resource.data.iv is string &&        // ← replaces type + registrationId
          request.resource.data.iv.size() > 0 &&
          request.resource.data.sentAt is timestamp &&
          request.resource.data.deliveredAt == null &&
          request.resource.data.readAt == null;
    
        // UPDATE: Only the RECIPIENT can update delivery/read receipts
        // Senders cannot mark their own messages as read (avoids spoofing)
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          request.auth.uid != resource.data.senderId &&
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.body == resource.data.body &&
          request.resource.data.iv == resource.data.iv &&        // ← replaces type + registrationId
          request.resource.data.sentAt == resource.data.sentAt &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deliveredAt', 'readAt']);
    
        // DELETE: Not allowed — message history is permanent
        allow delete: if false;
      }
    }

    // ============================================
    // PROVIDER DIRECTORY
    // ============================================

    match /providers_england/{providerId} {
      // Any authenticated user can read — needed for institution search in the request form
      allow read: if request.auth != null;

      // Writes are admin SDK only — data comes from ingestion scripts and sync functions
      allow write: if isServerWrite();
    }

    // ============================================
    // VERIFICATION CERTIFICATES
    // ============================================

    match /IdVerificationCertificates/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // SYSTEM QUEUES & LOGGING
    // ============================================

    match /blockchainSyncQueue/{queueId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.retryCount == 0;

      allow read, update: if request.auth != null &&
        (isPlatformAdmin() || resource.data.userId == request.auth.uid || isServerWrite());

      allow delete: if isServerWrite();
    }

    match /invites/{email} {
      allow read: if true; //unauthenticated signup
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['registeredUserId', 'registeredAt']);
    }

    match /waitlist/{email} {
      allow create: if true;              // unauthenticated signup
      allow read, update, delete: if false; // admin only
    }

    match /mailingList/{email} {
      allow create: if true;              // unauthenticated signup
      allow read, update, delete: if false; // admin only
    }

    match /audit/{auditId} {
      allow write: if request.auth != null;
      allow read: if false;
    }
  }
}
