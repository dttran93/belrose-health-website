{
  "compilerOptions": {
    "composite": true,
    "outDir": "lib",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
